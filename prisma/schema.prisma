generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  admin_id  Int    @id @default(autoincrement())
  person_id Int    @unique
  Person    Person @relation(fields: [person_id], references: [person_id])
}

model GoogleCalendarConnection {
  connection_id Int       @id @default(autoincrement())
  person_id     Int       @unique
  access_token  String
  refresh_token String?
  calendar_id   String?
  expires_at    DateTime?
  connected_at  DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  Person        Person    @relation(fields: [person_id], references: [person_id])
}

model Advisor {
  advisor_id        Int          @id @default(autoincrement())
  person_id         Int          @unique
  stripe_account_id String?
  stripe_status     StripeStatus @default(NOT_CONNECTED)
  hours             Int          @default(0)
  wage              Int          @default(0)
  Person            Person       @relation(fields: [person_id], references: [person_id])
}

model Assignment {
  assignment_id    Int      @id @default(autoincrement())
  document_id      Int      @unique
  completed        Boolean  @default(false)
  assignment_grade Int?
  Document         Document @relation(fields: [document_id], references: [document_id])
}

// One recurring weekly schedule per person. Only students, advisors, and
// tutors use this today -- admins have no sessions to be available for.
model Availability {
  availability_id  Int                @id @default(autoincrement())
  person_id        Int                @unique
  timezone         String             @default("America/New_York")
  AvailabilityRule AvailabilityRule[]
  DateOverride     DateOverride[]
  Person           Person             @relation(fields: [person_id], references: [person_id])
}

model AvailabilityRule {
  availability_rule_id Int          @id @default(autoincrement())
  availability_id      Int
  day_of_week          Int
  start_time           String
  end_time             String
  Availability         Availability @relation(fields: [availability_id], references: [availability_id], onDelete: Cascade)

  @@index([availability_id])
}

model DateOverride {
  date_override_id Int          @id @default(autoincrement())
  availability_id  Int
  date             DateTime     @db.Date
  start_time       String?
  end_time         String?
  is_blocked       Boolean      @default(false)
  Availability     Availability @relation(fields: [availability_id], references: [availability_id], onDelete: Cascade)

  @@index([availability_id])
}

model Document {
  document_id       Int                @id @default(autoincrement())
  person_id         Int
  title             String
  file_url          String
  private           Boolean            @default(true)
  date_uploaded     DateTime           @default(now())
  Assignment        Assignment?
  Person            Person             @relation(fields: [person_id], references: [person_id])
  MeetingTranscript MeetingTranscript?
  Test              Test?
}

// Infrastructure record for a session's Google Meet space -- the join/API
// details. Kept separate from Session (core business logic: the tutoring
// appointment, attendee, schedule, duration) so the Google Meet integration
// can be swapped out later without touching scheduling logic.
model GoogleMeetSpace {
  google_meet_space_id Int                @id @default(autoincrement())
  session_id           Int                @unique
  meeting_uri          String
  meeting_code         String?
  MeetingTranscript    MeetingTranscript?
  Session              Session            @relation(fields: [session_id], references: [session_id])
}

model MeetingTranscript {
  transcript_id        Int             @id @default(autoincrement())
  document_id          Int?            @unique
  session_id           Int             @unique
  google_meet_space_id Int             @unique
  fetch_status         FetchStatus     @default(PENDING)
  fetch_error          String?
  Document             Document?       @relation(fields: [document_id], references: [document_id])
  GoogleMeetSpace      GoogleMeetSpace @relation(fields: [google_meet_space_id], references: [google_meet_space_id])
  Session              Session         @relation(fields: [session_id], references: [session_id])
}

model PayAdjustment {
  pay_adjustment_id                                  Int     @id @default(autoincrement())
  previous_payment_id                                Int     @unique
  new_payment_id                                     Int     @unique
  Payment_PayAdjustment_new_payment_idToPayment      Payment @relation("PayAdjustment_new_payment_idToPayment", fields: [new_payment_id], references: [payment_id])
  Payment_PayAdjustment_previous_payment_idToPayment Payment @relation("PayAdjustment_previous_payment_idToPayment", fields: [previous_payment_id], references: [payment_id])
}

model PayPeriod {
  pay_period_id  Int              @id @default(autoincrement())
  period_start   DateTime         @db.Date
  period_end     DateTime         @db.Date
  Payment        Payment[]
  TimesheetEntry TimesheetEntry[]
}

model Payment {
  payment_id                                               Int            @id @default(autoincrement())
  pay_period_id                                            Int
  sender_id                                                Int
  recipient_id                                             Int
  stripe_transfer_id                                       String?
  created_at                                               DateTime       @default(now())
  payment_reason                                           PaymentReason
  status                                                   PaymentStatus  @default(PENDING_REVIEW)
  approved_by                                              Int?
  transaction_date                                         DateTime       @default(now())
  transaction_amount                                       Int
  failure_reason                                           String?
  PayAdjustment_PayAdjustment_new_payment_idToPayment      PayAdjustment? @relation("PayAdjustment_new_payment_idToPayment")
  PayAdjustment_PayAdjustment_previous_payment_idToPayment PayAdjustment? @relation("PayAdjustment_previous_payment_idToPayment")
  Person_Payment_approved_byToPerson                       Person?        @relation("Payment_approved_byToPerson", fields: [approved_by], references: [person_id])
  PayPeriod                                                PayPeriod      @relation(fields: [pay_period_id], references: [pay_period_id])
  Person_Payment_recipient_idToPerson                      Person         @relation("Payment_recipient_idToPerson", fields: [recipient_id], references: [person_id])
  Person_Payment_sender_idToPerson                         Person         @relation("Payment_sender_idToPerson", fields: [sender_id], references: [person_id])
}

model Person {
  person_id                            Int                       @id @default(autoincrement())
  name                                 String
  email                                String                    @unique
  phone                                String                    @unique @db.VarChar(15)
  username                             String                    @unique
  password                             String
  reschedules                          Int                       @default(0)
  clerk_id                             String?                   @unique
  Admin                                Admin?
  Advisor                              Advisor?
  Availability                         Availability?
  Document                             Document[]
  GoogleCalendarConnection             GoogleCalendarConnection?
  Payment_Payment_approved_byToPerson  Payment[]                 @relation("Payment_approved_byToPerson")
  Payment_Payment_recipient_idToPerson Payment[]                 @relation("Payment_recipient_idToPerson")
  Payment_Payment_sender_idToPerson    Payment[]                 @relation("Payment_sender_idToPerson")
  Schedule                             Schedule?
  SessionAttendants                    SessionAttendants[]
  Student                              Student?
  TimeMismatch                         TimeMismatch[]
  TimesheetEntry                       TimesheetEntry[]
  Tutor                                Tutor?
}

model Reminder {
  reminder_id   Int            @id @default(autoincrement())
  session_id    Int
  reminder_text String
  scheduled_at  DateTime
  type          ReminderType
  status        ReminderStatus @default(QUEUED)
  Session       Session        @relation(fields: [session_id], references: [session_id])
}

model Schedule {
  schedule_id Int       @id @default(autoincrement())
  person_id   Int       @unique
  Person      Person    @relation(fields: [person_id], references: [person_id])
  Session     Session[]
}

model Session {
  session_id          Int                 @id @default(autoincrement())
  schedule_id         Int
  session_date        DateTime
  session_description String?
  session_duration    Int?
  completed           Boolean             @default(false)
  GoogleMeetSpace     GoogleMeetSpace?
  MeetingTranscript   MeetingTranscript?
  Reminder            Reminder[]
  Schedule            Schedule            @relation(fields: [schedule_id], references: [schedule_id])
  SessionAttendants   SessionAttendants[]
  TimesheetEntry      TimesheetEntry?
}

model SessionAttendants {
  session_attendants_id Int       @id @default(autoincrement())
  session_id            Int
  person_id             Int
  arrival_time          DateTime? @db.Time(6)
  leave_time            DateTime? @db.Time(6)
  Person                Person    @relation(fields: [person_id], references: [person_id])
  Session               Session   @relation(fields: [session_id], references: [session_id])

  @@unique([session_id, person_id])
}

model Student {
  student_id            Int     @id @default(autoincrement())
  person_id             Int     @unique
  parent_phone          String  @db.VarChar(15)
  parent_email          String?
  absences              Int     @default(0)
  emergency_reschedules Int     @default(3)
  balance               Decimal @default(0) @db.Decimal(10, 2)
  prepaid_hours         Int     @default(0)
  Person                Person  @relation(fields: [person_id], references: [person_id])
}

model Test {
  test_id     Int      @id @default(autoincrement())
  document_id Int      @unique
  test_grade  Int?
  Document    Document @relation(fields: [document_id], references: [document_id])
}

model TimeMismatch {
  time_mismatch_id   Int            @id @default(autoincrement())
  timesheet_entry_id Int            @unique
  resolution_date    DateTime?
  resolved_by        Int?
  resolution_note    String?
  Person             Person?        @relation(fields: [resolved_by], references: [person_id])
  TimesheetEntry     TimesheetEntry @relation(fields: [timesheet_entry_id], references: [timesheet_entry_id])
}

model TimesheetEntry {
  timesheet_entry_id Int             @id @default(autoincrement())
  pay_period_id      Int
  session_id         Int             @unique
  person_id          Int
  date               DateTime        @db.Date
  start_time         DateTime        @db.Time(6)
  end_time           DateTime        @db.Time(6)
  timesheet_status   TimesheetStatus @default(PENDING)
  entry_reason       EntryReason
  correction         Int?
  TimeMismatch       TimeMismatch?
  PayPeriod          PayPeriod       @relation(fields: [pay_period_id], references: [pay_period_id])
  Person             Person          @relation(fields: [person_id], references: [person_id])
  Session            Session         @relation(fields: [session_id], references: [session_id])
}

model Tutor {
  tutor_id          Int          @id @default(autoincrement())
  person_id         Int          @unique
  stripe_account_id String?
  stripe_status     StripeStatus @default(NOT_CONNECTED)
  hours             Int          @default(0)
  wage              Int          @default(0)
  Person            Person       @relation(fields: [person_id], references: [person_id])
}

enum EntryReason {
  TUTOR_PAY
  ADVISOR_PAY
}

enum FetchStatus {
  PENDING
  FETCHING
  COMPLETED
  FAILED
}

enum PaymentReason {
  CLIENT_PAYMENT
  EMPLOYEE_PAYMENT
  EMPLOYEE_BONUS
  REFERRAL_BONUS
  CORRECTION
}

enum PaymentStatus {
  PENDING_REVIEW
  APPROVED
  PROCESSING
  PAID
  FAILED
}

enum ReminderStatus {
  QUEUED
  SENT
  FAILED
  CANCELED
}

enum ReminderType {
  EMAIL
  SMS
}

enum StripeStatus {
  NOT_CONNECTED
  PENDING
  VERIFIED
}

enum TimesheetStatus {
  PENDING
  FLAGGED
  APPROVED
  REJECTED
}
